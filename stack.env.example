# Portainer / Docker Compose — copy to `stack.env` on the server, or paste these lines into
# Portainer → Stacks → your stack → Environment variables.
#
# Important: Compose substitutes ${HOST_DATA_PATH} in docker-compose.yml using variables
# available when Compose *parses* the file. That usually means:
#   - a `.env` file next to docker-compose.yml (when you run `docker compose` on disk), or
#   - the "Environment variables" box Portainer shows when you deploy a stack (Portainer
#     injects them for interpolation).
#
# The optional `stack.env` in compose only loads into the *container* if the file exists;
# it does not replace the need to set HOST_DATA_PATH for volume mapping unless your setup
# exports those vars another way.

# --- Required for a real deployment ---
APP_PASSWORD=changeme
SESSION_SECRET=dev-insecure-change-me

# --- Host folder that becomes /data in the container (SYNOLOGY EXAMPLE) ---
# HOST_DATA_PATH=/volume1/Backups/drive-to-nas

# Local dev default in compose is ./data if unset
HOST_DATA_PATH=./data

# Paths inside the container (normally leave as-is)
DATA_DIR=/data

# Optional UI default (must be under DATA_DIR, e.g. /data/exports)
# DEFAULT_OUTPUT_PATH=/data/exports
