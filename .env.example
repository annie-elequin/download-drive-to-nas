# Copy to .env and edit. The app loads .env from the project root (see app/main.py).
# Docker Compose also reads `.env` here for ${VAR} substitution in docker-compose.yml
# (e.g. HOST_DATA_PATH for the bind mount). .env is gitignored.

APP_PASSWORD=changeme
SESSION_SECRET=dev-insecure-change-me

# Host directory mounted as /data inside the container (compose volumes: left side).
# Example on Synology: HOST_DATA_PATH=/volume1/Backups/drive-to-nas
HOST_DATA_PATH=./data

# Root directory for output; all destination paths must be inside this tree.
# Docker: leave as /data (matches the volume mount in docker-compose.yml).
# Local (no Docker): point at a folder on your machine, e.g.:
# DATA_DIR=/Users/you/Downloads/drive-to-nas-output
DATA_DIR=/data

# Optional: prefilled destination in the web form (must be under DATA_DIR).
# Leave blank to use <DATA_DIR>/exports.
# DEFAULT_OUTPUT_PATH=
